{
  "name": "startername",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --recursive run dev",
    "build": "pnpm --recursive run build",
    "test": "pnpm --recursive --stream run test",
    "check-types": "pnpm --recursive --stream --no-bail run check-types",
    "prettify": "pnpm --recursive run prettify",
    "lint": "pnpm --recursive --stream run lint",
    "prepare": "husky",
    "commit": "cz",
    "update:workspaces": "pnpm update --interactive --recursive"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "commitizen": "4.3.1",
    "cz-git": "1.12.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "rimraf": "6.1.2",
    "tsx": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git",
      "czConfig": "./cz.config.cjs"
    }
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": "24.13.0",
    "pnpm": ">=10.0.0"
  }
}
